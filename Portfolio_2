class BankCard:
    def __init__(self, card_number, holder):
        self.card_number = card_number
        self.holder = holder
        # 1. Используем _balance, чтобы скрыть его от прямого изменения
        self._balance = 0 
        self.max_limit = 50000
        self.history = []

    # 2. ДЕКОРАТОР @property
    # Это позволяет обращаться к card.balance как к переменной, 
    # хотя на самом деле будет вызываться этот метод.
    @property
    def balance(self):
        """Возвращает текущий баланс (только для чтения снаружи)"""
        return self._balance

    def deposit(self, amount):
        # Используем self._balance внутри класса напрямую
        if self._balance + amount > self.max_limit:
            print(f"❌ Ошибка: У {self.holder} превышен лимит карты!")
            return False

        self._balance += amount
        self.history.append(f"Пополнение: +{amount} (Баланс: {self._balance})")
        print(f"✅ Пополнение у {self.holder} на {amount}. Баланс: {self._balance}")
        return True

    def withdraw(self, amount):
        if amount <= self._balance:
            self._balance -= amount
            # Исправил опечатку в истории (было + стало -)
            self.history.append(f"Снятие: -{amount} (Баланс: {self._balance})")
            print(f"✅ Снято {amount}. Остаток {self.holder}: {self._balance}")
            return True
        else:
            print(f"❌ {self.holder}: Недостаточно средств!")
            return False

    def transfer(self, to_card, amount):
        print(f"\n--- 💸 Перевод: {self.holder} -> {to_card.holder} ({amount} руб) --- ")

        # 3. ПРОВЕРКА ТИПА (isinstance)
        # Проверяем, что to_card — это объект BankCard или его наследник
        if not isinstance(to_card, BankCard):
            print(f"❌ Ошибка: {to_card} не является банковской картой!")
            return False

        if self.withdraw(amount):
            if to_card.deposit(amount):
                self.history.append(f"Перевод к {to_card.holder}: -{amount}")
                print("✨ Транзакция прошла успешно!")
                return True
            else:
                print(f"⚠️ Отмена! Возвращаем {amount} обратно {self.holder}...")
                self._balance += amount
                self.history.append(f"Откат перевода: +{amount}")
                return True
        return False

class DebitCard(BankCard):
    def __init__(self, card_number, holder, cashback_percent=1):
        super().__init__(card_number, holder)
        self.cashback_percent = cashback_percent
        self.accumulated_cashback = 0

    def pay(self, amount):
        # Обращаемся к self._balance, так как мы наследник
        if amount <= self._balance:
            self._balance -= amount
            bonus = amount * (self.cashback_percent / 100)
            self.accumulated_cashback += bonus
            self.history.append(f"Оплата: -{amount}. Кэшбэк: +{bonus}")
            print(f"🛍 Оплата {amount}. Кэшбэк: {bonus}. Баланс: {self._balance}")
        else:
            print("❌ Пополните баланс для покупки!")

    def convert_cashback(self):
        old_bonus = self.accumulated_cashback
        if old_bonus > 0:
            print(f"🔄 Конвертируем кэшбэк: {old_bonus} руб...")
            if self.deposit(old_bonus):
                self.accumulated_cashback = 0
                return True
        return False

    def show_history(self):
        print(f"\n--- 📜 ИСТОРИЯ ({self.holder}) ---")
        for record in self.history:
            print(f"  {record}")
        print("------------------------------\n")
